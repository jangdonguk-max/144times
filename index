<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<meta name="theme-color" content="#fdfaf7">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<meta name="apple-mobile-web-app-title" content="TimeStrip">
<meta name="description" content="하루를 10분 단위로 기록하는 타임 트래커">
<link rel="apple-touch-icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' rx='22' fill='%23fdfaf7'/%3E%3Crect x='18' y='20' width='12' height='60' rx='4' fill='%23a8c4e0'/%3E%3Crect x='34' y='30' width='12' height='50' rx='4' fill='%23a8d4b4'/%3E%3Crect x='50' y='15' width='12' height='65' rx='4' fill='%23f0c080'/%3E%3Crect x='66' y='25' width='12' height='55' rx='4' fill='%23c4a8d8'/%3E%3C/svg%3E">
<title>TimeStrip</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#f5f0eb;--surf:#fdfaf7;--surf2:#f0ebe4;--bdr:#e2d9ce;
  --txt:#3a2e28;--mut:#9a8a7e;--acc:#b89a82;
  --r:16px;--rs:10px;
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html,body{height:100%;overflow:hidden}
body{background:var(--bg);color:var(--txt);font-family:'Nunito',sans-serif;display:flex;flex-direction:column}

/* NAV */
nav{display:flex;align-items:center;padding:8px 12px;background:var(--surf);border-bottom:2px solid var(--bdr);gap:8px;flex-shrink:0}
.logo{font-size:17px;font-weight:800;white-space:nowrap}
.logo span{color:var(--acc)}
.nav-tabs{display:flex;gap:2px;background:var(--surf2);border-radius:8px;padding:2px;flex-shrink:0}
.nav-tab{padding:5px 10px;border-radius:6px;cursor:pointer;font-size:11px;font-weight:700;color:var(--mut);border:none;background:none;font-family:'Nunito',sans-serif;transition:all .2s;white-space:nowrap}
.nav-tab.active{background:var(--surf);color:var(--txt);box-shadow:0 1px 4px rgba(0,0,0,.08)}

/* HAMBURGER */
.hbg-btn{width:34px;height:34px;border-radius:var(--rs);background:var(--surf2);border:2px solid var(--bdr);cursor:pointer;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;margin-left:auto;flex-shrink:0;transition:all .15s}
.hbg-btn:hover{background:var(--bdr)}
.hbg-line{width:14px;height:2px;background:var(--mut);border-radius:2px;transition:all .2s}
.hbg-btn.open .hbg-line:nth-child(1){transform:translateY(6px) rotate(45deg)}
.hbg-btn.open .hbg-line:nth-child(2){opacity:0}
.hbg-btn.open .hbg-line:nth-child(3){transform:translateY(-6px) rotate(-45deg)}

/* SIDE DRAWER */
.drawer-backdrop{position:fixed;inset:0;background:rgba(58,46,40,.25);backdrop-filter:blur(2px);z-index:200;display:none;opacity:0;transition:opacity .25s}
.drawer-backdrop.open{display:block;opacity:1}
.drawer{position:fixed;top:0;right:-240px;width:230px;height:100%;background:var(--surf);border-left:2px solid var(--bdr);z-index:201;transition:right .25s cubic-bezier(.25,.1,.25,1);display:flex;flex-direction:column;box-shadow:-8px 0 32px rgba(58,46,40,.12)}
.drawer.open{right:0}
.drawer-hd{padding:16px 16px 12px;border-bottom:2px solid var(--bdr);display:flex;align-items:center;justify-content:space-between}
.drawer-logo{font-size:15px;font-weight:800;color:var(--txt)}
.drawer-logo span{color:var(--acc)}
.drawer-x{background:var(--surf2);border:none;width:26px;height:26px;border-radius:7px;cursor:pointer;font-size:13px;color:var(--mut);display:flex;align-items:center;justify-content:center;transition:all .15s}
.drawer-x:hover{background:var(--bdr)}
.drawer-section{padding:10px 10px 4px;font-size:9px;font-weight:700;color:var(--mut);letter-spacing:.08em;font-family:'DM Mono',monospace}
